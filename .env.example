# ─────────────────────────────────────────────────────────────────────────────
# Contact form configuration. Copy this file to `.env.local` and fill in real
# values. `.env.local` is gitignored — never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# Resend — transactional email API used to deliver contact-form inquiries.
# Create an API key: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
# "From" address, on a domain verified in Resend (https://resend.com/domains).
# For quick testing before verifying your domain, use onboarding@resend.dev
# (delivers only to the email on your Resend account).
RESEND_FROM=noreply@sonomascholars.com

# Google reCAPTCHA v3 keys — https://www.google.com/recaptcha/admin
# Register the site as reCAPTCHA v3 and add your domain(s) + localhost.
# The SITE key is public (shipped to the browser); the SECRET key is private.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-v3-secret-key
